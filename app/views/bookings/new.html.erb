<h1>🎬 Book Tickets for <%= @movie.title %></h1>

<% if @booking.errors.any? %>
  <div style="color:red; border: 1px solid red; padding: 10px;">
    <h3>Please fix these errors:</h3>
    <% @booking.errors.full_messages.each do |message| %>
      <p><%= message %></p>
    <% end %>
  </div>
<% end %>

<%= form_with model: [@movie, @booking], data: { turbo: false } , authenticity_token: true do |form| %>
```
  <p>
    <%= form.label :name, "Your Name" %><br>
    <%= form.text_field :name %>
  </p>

  <p>
    <%= form.label :email, "Your Email" %><br>
    <%= form.email_field :email %>
  </p>

  <p>
    <%= form.label :seats, "Number of Seats" %><br>
    <%= form.number_field :seats, min: 1 %>
  </p>

  <%= form.submit "Book Now! 🎬" %>
<% end %>

<%= link_to "Back to Movie", movie_path(@movie) %>
