<h1>🎬 Now Showing</h1>

<% @movies.each do |movie| %>
  <div class="movie-card">
    <h2><%= movie.title %></h2>
    <p>🎭 Genre: <%= movie.genre %></p>
    <p>⏱️ Duration: <%= movie.duration %> mins</p>
    <p><%= movie.description %></p>
    <%= link_to "View Details & Book 🎟️", movie_path(movie) %>
  </div>
<% end %>
